{
  "hosting": [
    {
      "target": "invoaura-crm",
      "public": ".output/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "/node_modules/"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}